{
  "name": "VIAudioKit",
  "version": "0.1.0",
  "summary": "Cross-platform audio player with chunked downloading, custom decoding and AVAudioEngine rendering.",
  "homepage": "https://github.com/example/VIAudioKit",
  "license": {
    "type": "MIT",
    "file": "LICENSE"
  },
  "authors": {
    "VIAudioKit": "dev@example.com"
  },
  "source": {
    "git": "https://github.com/example/VIAudioKit.git",
    "tag": "0.1.0"
  },
  "platforms": {
    "ios": "15.0",
    "osx": "12.0"
  },
  "swift_versions": "5.9",
  "static_framework": true,
  "default_subspecs": "Core",
  "subspecs": [
    {
      "name": "Core",
      "source_files": [
        "Sources/VIAudioDownloader/**/*.swift",
        "Sources/VIAudioDecoder/**/*.swift",
        "Sources/VIAudioPlayer/**/*.swift"
      ],
      "frameworks": [
        "Foundation",
        "AVFoundation",
        "AudioToolbox",
        "Network",
        "CryptoKit"
      ],
      "pod_target_xcconfig": {
        "SWIFT_ACTIVE_COMPILATION_CONDITIONS": "COCOAPODS"
      }
    },
    {
      "name": "FFmpeg",
      "dependencies": {
        "VIAudioKit/Core": [

        ],
        "ffmpeg-kit-ios-full": [

        ]
      },
      "source_files": "Sources/VIAudioFFmpeg/**/*.{swift,h,m,c}",
      "preserve_paths": "Sources/VIAudioFFmpeg/include/module.modulemap",
      "pod_target_xcconfig": {
        "SWIFT_ACTIVE_COMPILATION_CONDITIONS": "COCOAPODS",
        "SWIFT_INCLUDE_PATHS": "$(PODS_TARGET_SRCROOT)/Sources/VIAudioFFmpeg/include",
        "USER_HEADER_SEARCH_PATHS": "$(inherited) ${PODS_ROOT}/ffmpeg-kit-ios-full/ffmpegkit.xcframework/ios-arm64/ffmpegkit.framework/Headers"
      }
    }
  ],
  "swift_version": "5.9"
}
